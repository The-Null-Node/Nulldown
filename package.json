{
  "name": "nulldown",
  "version": "1.0.0",
  "private": true,
  "description": "A simple markdown sharing tool",
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "lint": "bunx --bun eslint .",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "pages:build": "bunx --bun vite build",
    "pages:dev": "bun run build && wrangler pages dev dist --live-reload",
    "pages:dev:remote": "bun run build && wrangler pages dev dist --live-reload --remote",
    "deploy": "bun run pages:build && wrangler pages deploy dist"
  },
  "keywords": [
    "markdown",
    "sharing",
    "cloudflare"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.797.0",
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "katex": "^0.16.22",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.6.0",
    "nanoid": "^5.0.0",
    "react-katex": "^3.1.0",
    "react-markdown": "^8.0.7",
    "react-router-dom": "^7.6.0",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^3.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unified": "^11.0.5",
    "vfile": "^6.0.3",
    "vfile-message": "^4.0.2",
    "zustand": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260103.0",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/vite": "^4.2.0",
    "@types/katex": "^0.16.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react-katex": "^3.0.4",
    "@types/react-syntax-highlighter": "^15.5.11",
    "@vitejs/plugin-react": "^4.0.0",
    "jest": "^29.7.0",
    "fake-indexeddb": "^6.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9",
    "tailwindcss": "^4",
    "ts-jest": "^29.2.5",
    "typescript": "^5",
    "vite": "^5.0.0",
    "wrangler": "^3.0.0"
  }
}
